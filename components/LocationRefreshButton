// components/LocationRefreshButton.tsx
"use client";
import { useState } from "react";

export default function LocationRefreshButton({ onUpdate }: { onUpdate: (lat: number, lng: number) => void }) {
  const [busy, setBusy] = useState(false);

  const refresh = () => {
    if (!navigator.geolocation) return alert("Location not supported");
    setBusy(true);
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        onUpdate(pos.coords.latitude, pos.coords.longitude);
        setBusy(false);
      },
      () => { setBusy(false); alert("Couldn't get your location."); },
      { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
    );
  };

  return (
    <button
      onClick={refresh}
      className="fixed bottom-4 right-4 z-50 rounded-full px-4 py-3 shadow-lg bg-black text-white text-sm md:text-base active:scale-[0.98]"
      aria-label="Use my location"
    >
      {busy ? "Locating…" : "Use my location"}
    </button>
  );
}
